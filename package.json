{
	"name": "obsidian-block-view",
	"version": "1.0.0",
	"description": "An Obsidian Bases view that turns your notes into a database of blocks.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "bun test",
		"format": "prettier --write src"
	},
	"keywords": [],
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"eslint": "^9.39.4",
		"@semantic-release/exec": "^7.1.0",
		"@semantic-release/git": "^10.0.1",
		"@types/bun": "^1.3.14",
		"@types/node": "^16.18.126",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "^0.4.1",
		"globals": "^17.7.0",
		"jiti": "2.6.1",
		"prettier": "^3.9.4",
		"semantic-release": "^25.0.5",
		"tslib": "2.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.62.1"
	},
	"dependencies": {
		"obsidian": "^1.13.1"
	}
}
