		"handlebars": "^4.7.9",
		"ip-address": "^10.2.0",
		"js-yaml": "^4.3.0",
		"lodash": "^4.18.1",
		"lodash-es": "^4.18.1",
		"minimatch": "^3.1.5",
		"picomatch": "^2.3.2",
		"sigstore": "^5.0.0",
		"tar": "^7.5.19",
		"yaml": "^2.9.0"
